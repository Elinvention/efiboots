<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>ovh.elinvention.Efiboots</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Efiboots</name>
  <summary>Manage EFI boot loader entries with this simple GUI</summary>
  <description>
    <p>
      Efiboots is a simple and intuitive graphical interface designed to manage your system's EFI boot loader entries.
      It allows you to view, add, remove, and reorder boot entries without having to manually use command-line tools like efibootmgr.
      You can use this tool a bit like bcdedit on Windows.
      You can also set which entry to boot next and reboot your computer.
    </p>
  </description>

  <developer id="ovh.elinvention">
    <name>Elia Argentieri</name>
  </developer>

  <!-- Required: Should be a link to the upstream homepage for the component -->
  <url type="homepage">https://github.com/Elinvention/efiboots</url>
  <!-- Recommended: It is highly recommended for open-source projects to display the source code repository -->
  <url type="vcs-browser">https://github.com/Elinvention/efiboots</url>
  <!-- Should point to the software's bug tracking system, for users to report new bugs -->
  <url type="bugtracker">https://github.com/Elinvention/efiboots/issues</url>
  <!-- Should link a FAQ page for this software, to answer some of the most-asked questions in detail -->
  <url type="faq">https://github.com/Elinvention/efiboots/blob/main/README.md</url>
  <!-- URLs of this type should point to a webpage where users can submit or modify translations of the upstream project -->
  <url type="translate">https://github.com/Elinvention/efiboots/blob/main/README.md</url>
  <!-- Should provide a web link to an online user's reference, a software manual or help page -->
  <url type="help">https://github.com/Elinvention/efiboots/blob/main/README.md</url>
  <!-- URLs of this type should point to a webpage showing information on how to donate to the described software project -->
  <url type="donation">https://liberapay.com/Elinvention</url>
  <!-- This could for example be an HTTPS URL to an online form or a page describing how to contact the developer -->
  <url type="contact">https://elinvention.ovh/informazioni/</url>
  <!-- URLs of this type should point to a webpage showing information on how to contribute to the described software project -->
  <url type="contribute">https://github.com/Elinvention/efiboots/blob/main/README.md</url>

  <translation type="gettext">efiboots</translation>
  <!-- All graphical applications having a desktop file must have this tag in the MetaInfo.
     If this is present, appstreamcli compose will pull icons, keywords and categories from the desktop file. -->
  <launchable type="desktop-id">ovh.elinvention.Efiboots.desktop</launchable>
  <!-- Use the OARS website (https://hughsie.github.io/oars/generate.html) to generate these and make sure to use oars-1.1 -->
  <content_rating type="oars-1.1" />

  <categories>
    <category>Settings</category>
    <category>System</category>
    <category>HardwareSettings</category>
  </categories>

  <!-- Applications should set a brand color in both light and dark variants like so -->
  <branding>
    <color type="primary" scheme_preference="light">#ff00ff</color>
    <color type="primary" scheme_preference="dark">#993d3d</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/Elinvention/efiboots/main/screenshot.png</image>
      <caption>The main window showing boot entries</caption>
    </screenshot>
  </screenshots>

  <releases>
    <release version="3.0.0" date="2025-06-02">
      <url type="details">https://github.com/Elinvention/efiboots/releases/tag/3.0.0</url>
      <description translate="no">
        <p>Release description</p>
        <ul>
          <li>First Flatpak release</li>
          <li>Use GNOME Builder's template for the app</li>
        </ul>
      </description>
    </release>
  </releases>

</component>

